  <script src="{% static 'bootstrap-5.3.8-dist/js/bootstrap.bundle.min.js' %}"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
  <script src="{% static 'js/no-autocomplete.js' %}"></script>
  <script>
    const summaryFromServer = JSON.parse(document.getElementById("resumen-data").textContent);
    const detailFromServer = JSON.parse(document.getElementById("detalle-data").textContent);

    const chartColors = {
      primary: "#c62828",
      secondary: "#fbc02d",
      warning: "#ef6c00",
      success: "#fbc02d",
      neutral: "#b08968"
    };

    function safeNumber(value, defaultValue = 0) {
      const parsed = Number(value);
      return Number.isFinite(parsed) ? parsed : defaultValue;
    }

    function animateValue(element, finalValue, suffix = "") {
      const duration = 700;
      const start = 0;
      const startTime = performance.now();

      function tick(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const current = Math.round(start + (finalValue - start) * progress);
        element.textContent = current + suffix;
        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      }

      requestAnimationFrame(tick);
    }

    function formatNow() {
      return new Date().toLocaleString("es-MX", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
      });
    }

      function buildDoughnut(labels, values) {
        const ctx = document.getElementById("estadoChart").getContext("2d");

        const palette = [
          "#c62828",
          "#ef6c00",
          "#fbc02d",
          "#ff9800",
          "#b71c1c",
          "#8e0000",
          "#ffb300",
          "#bf360c",
          "#7f1d1d",
          "#ffcc80",
          "#d84315",
          "#ffd54f",
        ];

        const normalized = new Map();
        (labels || []).forEach((raw, idx) => {
          const key = (raw || "").trim() || "SIN LISTA";
          const count = safeNumber((values || [])[idx], 0);
          normalized.set(key, (normalized.get(key) || 0) + count);
        });

        const finalLabels = Array.from(normalized.keys());
        const finalValues = finalLabels.map((k) => normalized.get(k));
        const finalColors = finalLabels.map((_, idx) => palette[idx % palette.length]);

        const legendPosition = window.matchMedia("(min-width: 992px)").matches ? "right" : "bottom";

        new Chart(ctx, {
          type: "doughnut",
          data: {
            labels: finalLabels,
            datasets: [{
              data: finalValues,
              backgroundColor: finalColors,
              borderWidth: 0
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: legendPosition,
                labels: {
                  boxWidth: 10,
                  boxHeight: 10,
                  padding: 10,
                  font: { size: 11 },
                }
              }
            }
          }
        });
      }

    function buildLineChart(labels, values) {
      const ctx = document.getElementById("ingresosChart").getContext("2d");

      new Chart(ctx, {
        type: "line",
        data: {
          labels,
          datasets: [{
            label: "Ingresos",
            data: values,
            borderColor: chartColors.primary,
            backgroundColor: "rgba(198, 40, 40, 0.12)",
            fill: true,
            tension: 0.3,
            pointRadius: 4,
            pointHoverRadius: 5
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                precision: 0
              }
            }
          }
        }
      });
    }

    function buildBarChart(labels, values) {
      const ctx = document.getElementById("tipoChart").getContext("2d");

      new Chart(ctx, {
        type: "bar",
        data: {
          labels,
          datasets: [{
            label: "Clientes",
            data: values,
            backgroundColor: [
              "#c62828",
              "#ef6c00",
              "#fbc02d",
              "#ff9800",
              "#ffd8a8"
            ],
            borderRadius: 8,
            maxBarThickness: 38
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                precision: 0
              }
            }
          }
        }
      });
    }

    async function loadData() {
      const total = safeNumber(summaryFromServer && summaryFromServer.total, 0);
      const pendientes = safeNumber(summaryFromServer && summaryFromServer.pendientes, 0);
      const liberados = safeNumber(summaryFromServer && summaryFromServer.liberados, 0);
      const tasaLiberacion = total > 0 ? Math.round((liberados / total) * 100) : 0;

      animateValue(document.getElementById("Clientes"), total);
      animateValue(document.getElementById("pendientes"), pendientes);
      animateValue(document.getElementById("liberados"), liberados);
      animateValue(document.getElementById("tasaLiberacion"), tasaLiberacion, "%");

      document.getElementById("lastUpdate").textContent = formatNow();

      const monthlyLabels = (detailFromServer && Array.isArray(detailFromServer.monthlyLabels) && detailFromServer.monthlyLabels.length)
        ? detailFromServer.monthlyLabels
        : [];
      const monthlyIngress = (detailFromServer && Array.isArray(detailFromServer.monthlyIngress) && detailFromServer.monthlyIngress.length)
        ? detailFromServer.monthlyIngress
        : [];
      const typeLabels = (detailFromServer && Array.isArray(detailFromServer.typeLabels) && detailFromServer.typeLabels.length)
        ? detailFromServer.typeLabels
        : [];
      const typeValues = (detailFromServer && Array.isArray(detailFromServer.typeValues) && detailFromServer.typeValues.length)
        ? detailFromServer.typeValues
        : [];
      const listaLabels = (detailFromServer && Array.isArray(detailFromServer.labels) && detailFromServer.labels.length)
        ? detailFromServer.labels
        : [];
      const listaValues = (detailFromServer && Array.isArray(detailFromServer.values) && detailFromServer.values.length)
        ? detailFromServer.values
        : [];

      buildDoughnut(listaLabels, listaValues);
      buildLineChart(monthlyLabels, monthlyIngress);
      buildBarChart(typeLabels, typeValues);
    }

    loadData();
  </script>
</body>
</html>
